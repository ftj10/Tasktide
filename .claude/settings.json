{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Read(backend/.env)",
      "Edit(backend/.env)",
      "Write(backend/.env)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq --rawfile contents .claude/settings.json -n '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": (\".claude/settings.json:\\n\" + $contents)}}'",
            "statusMessage": "Loading settings.json into context..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "codex@openai-codex": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  }
}
